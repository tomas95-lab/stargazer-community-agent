COMMUNITY_BASE_URL=https://community.outlier.ai
COMMUNITY_CATEGORY_SLUG=stargazer-axiom
COMMUNITY_CATEGORY_ID=15895
COMMUNITY_CHAT_CHANNEL_ID=828853
DISCOURSE_API_KEY=your_user_api_key_here
DISCOURSE_API_CLIENT_ID=daily-thread-bot
DISCOURSE_USERNAME=your_discourse_username

# Required by protected API routes. Use the same value in the UI Settings page.
ADMIN_TOKEN=replace_with_a_long_random_token

# Required by Vercel Cron. Vercel sends it as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=replace_with_a_long_random_token

# Optional external scheduler. Used by `npm run scheduler:setup:cron-job-org`.
CRON_JOB_ORG_API_KEY=your_cron_job_org_api_key_here
CRON_TARGET_BASE_URL=https://stargazer-community-agent.vercel.app

# GitHub storage used by the web API.
DATA_STORE=github
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=tomas95-lab
GITHUB_REPO=stargazer-community-agent

# Claude community agent.
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-haiku-4-5
AGENT_AUTO_POST=false
AGENT_MAX_ANSWERS=4
AGENT_MESSAGE_COUNT=50
AGENT_MIN_CONFIDENCE=0.50
DM_REVIEW_MESSAGE_COUNT=50
DM_REVIEW_MAX_CHANNELS=5
DM_REVIEW_REQUEST_DELAY_MS=1500
DM_AUTO_REPLY=false
DM_AUTO_REPLY_MAX=3

# Optional AI usage guardrails. When enforce is false, the app only tracks usage.
AI_DAILY_TOKEN_LIMIT=
AI_DAILY_CALL_LIMIT=
AI_GUARDRAILS_ENFORCE=false

# Claude DM replies use the same confidence/safety gate as the community agent.
DISCOURSE_RATE_LIMIT_RETRIES=2
DISCOURSE_RATE_LIMIT_MAX_WAIT_SECONDS=30

# Local jobs. Keep daily publish disabled unless a scheduler should publish.
DAILY_PUBLISH_ENABLED=false
DAILY_PUBLISH_POST_CHAT=true
FORCE_DAILY_PUBLISH=false

# Local server.
SERVER_PORT=3001
