COMMUNITY_BASE_URL=https://community.outlier.ai
COMMUNITY_CATEGORY_SLUG=stargazer-axiom
COMMUNITY_CATEGORY_ID=15895
COMMUNITY_CHAT_CHANNEL_ID=828853
DISCOURSE_API_KEY=your_user_api_key_here
DISCOURSE_API_CLIENT_ID=daily-thread-bot
DISCOURSE_USERNAME=your_discourse_username
APP_TIME_ZONE=America/Los_Angeles
APP_TIME_ZONE_LABEL=PST

# Required by protected API routes. Use the same value in the UI Settings page.
ADMIN_TOKEN=replace_with_a_long_random_token

# Required by protected cron routes and external schedulers.
# Vercel Cron is also accepted when its schedule headers match vercel.json.
CRON_SECRET=replace_with_a_long_random_token

# Optional external scheduler. Used by `npm run scheduler:setup:cron-job-org`.
CRON_JOB_ORG_API_KEY=your_cron_job_org_api_key_here
CRON_TARGET_BASE_URL=https://stargazer-community-agent.vercel.app

# Supabase is the production content store. Use local only for development.
STORAGE_BACKEND=supabase
# Temporary migration fallback. Remove this and the GitHub variables after verification.
STORAGE_FALLBACK=
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Claude community agent.
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-haiku-4-5
AGENT_AUTO_POST=false
AGENT_MAX_ANSWERS=4
AGENT_MESSAGE_COUNT=50
AGENT_THREAD_SCAN_LIMIT=6
AGENT_THREAD_MESSAGE_COUNT=30
AGENT_MIN_CONFIDENCE=0.50
AGENT_PST_START_HOUR=
AGENT_PST_END_HOUR=
DM_REVIEW_MESSAGE_COUNT=50
DM_REVIEW_MAX_CHANNELS=5
DM_REVIEW_REQUEST_DELAY_MS=1500
DM_AUTO_REPLY=false
DM_AUTO_REPLY_MAX=3

# Optional AI usage guardrails. When enforce is false, the app only tracks usage.
AI_DAILY_TOKEN_LIMIT=
AI_DAILY_CALL_LIMIT=
AI_GUARDRAILS_ENFORCE=false

# Isolated public demo account. The seed script copies an existing QM Claude key
# without exposing it and enforces 12 calls / 12,000 tokens per day.
DEMO_USER_EMAIL=testing@demo.local
DEMO_USER_PASSWORD=testing
DEMO_AI_SOURCE_EMAIL=your_qm_email@example.com

# Claude DM replies use the same confidence/safety gate as the community agent.
DISCOURSE_RATE_LIMIT_RETRIES=2
DISCOURSE_RATE_LIMIT_MAX_WAIT_SECONDS=30

# Local jobs. Keep daily publish disabled unless a scheduler should publish.
DAILY_PUBLISH_ENABLED=false
DAILY_PUBLISH_POST_CHAT=true
FORCE_DAILY_PUBLISH=false

# Local server.
SERVER_PORT=3001

# Multi-user platform security. Generate a dedicated random 32+ byte value.
PLATFORM_ENCRYPTION_KEY=replace_with_a_dedicated_random_secret
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_server_secret_key

# Browser push notifications. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com
