{
  "version": 2,
  "buildCommand": "npm install && cd ui && npm install && npm run build",
  "outputDirectory": "ui/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "{data,templates}/**"
    }
  },
  "crons": [
    { "path": "/api/cron/daily-thread/1000", "schedule": "0 13 * * *" },
    { "path": "/api/cron/daily-thread/1100", "schedule": "0 14 * * *" },
    { "path": "/api/cron/community-agent/1000", "schedule": "0 13 * * *" },
    { "path": "/api/cron/community-agent/1130", "schedule": "30 14 * * *" },
    { "path": "/api/cron/community-agent/1300", "schedule": "0 16 * * *" },
    { "path": "/api/cron/community-agent/1430", "schedule": "30 17 * * *" },
    { "path": "/api/cron/community-agent/1600", "schedule": "0 19 * * *" },
    { "path": "/api/cron/community-agent/1730", "schedule": "30 20 * * *" },
    { "path": "/api/cron/community-agent/1900", "schedule": "0 22 * * *" },
    { "path": "/api/cron/dm-review/1530", "schedule": "30 18 * * *" },
    { "path": "/api/cron/dm-review/1800", "schedule": "0 21 * * *" }
  ]
}
