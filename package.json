{
  "name": "daily-thread-bot",
  "version": "1.0.0",
  "description": "Automation tool for publishing Stargazer Axiom daily threads",
  "main": "dist/index.js",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "test": "npm run build && node --test tests/*.test.mjs",
    "daily": "npm run build && node dist/index.js",
    "daily:dev": "node node_modules/tsx/dist/cli.mjs src/index.ts",
    "server": "node node_modules/tsx/dist/cli.mjs server/index.ts",
    "ui:dev": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "dev": "node scripts/dev.mjs",
    "start": "npm --prefix ui run build && node node_modules/tsx/dist/cli.mjs server/index.ts",
    "comms": "node node_modules/tsx/dist/cli.mjs src/comms/index.ts",
    "mcp": "node node_modules/tsx/dist/cli.mjs src/mcp-server.ts",
    "job:daily": "node node_modules/tsx/dist/cli.mjs src/daily-publish-job.ts",
    "job:dms": "node node_modules/tsx/dist/cli.mjs src/dm-review-job.ts",
    "job:webinars": "node node_modules/tsx/dist/cli.mjs src/webinar-reminder.ts",
    "jobs:all": "node node_modules/tsx/dist/cli.mjs src/run-community-jobs.ts",
    "scheduler:setup:cron-job-org": "node scripts/setup-cron-job-org.mjs",
    "ai:respond": "node node_modules/tsx/dist/cli.mjs src/claude-responder.ts",
    "training:scan": "node node_modules/tsx/dist/cli.mjs src/manager-training-scan.ts",
    "guidelines:extract": "node scripts/extract-guidelines.mjs",
    "storage:migrate": "node node_modules/tsx/dist/cli.mjs src/migrate-data-store.ts",
    "storage:migrate:operations": "node node_modules/tsx/dist/cli.mjs src/migrate-operational-history.ts",
    "demo:seed": "node node_modules/tsx/dist/cli.mjs src/seed-demo-account.ts",
    "storage:verify": "node node_modules/tsx/dist/cli.mjs src/migrate-data-store.ts --verify"
  },
  "keywords": [],
  "license": "PRIVATE",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^0.1.80",
    "@supabase/supabase-js": "^2.110.5",
    "clipboardy": "^4.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "pdf-parse": "^2.4.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
